# 📚 Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import KFold
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import r2_score, mean_squared_error
from tensorflow.keras.models import Sequential, load_model
from tensorflow.keras.layers import Dense, Dropout
from tensorflow.keras.optimizers import Adam
import tensorflow as tf
import json
import os

# 📂 Load Data
data_path = "E:/F_Data/Experiment_1/7.Growing season month/1. CSV_File/Combined_Growing.csv"
df = pd.read_csv(data_path)
df.dropna(inplace=True)

# 🔍 Feature and Target Selection
features = ['EDI', 'PAI', 'PCI', 'SPEI3', 'SPEI6', 'SPEI12', 
            'SPI3', 'SPI6', 'SPI12', 'TCI', 'VCI', 'VHI']
target = 'SMDI'

# 🔄 Normalize Features
scaler = MinMaxScaler()
df[features] = scaler.fit_transform(df[features])

# 🧪 Sample 130000 records
df_sampled = df.sample(n=130000, random_state=42)
X = df_sampled[features].values
y = df_sampled[target].values

# 📏 Prepare for CV
r2_scores, rmse_scores, mse_scores = [], [], []
train_true_all, train_pred_all = [], []
test_true_all, test_pred_all = [], []
history_all = []

kf = KFold(n_splits=5, shuffle=True, random_state=42)

# 🧠 Model Definition (Simplified to Reduce Overfitting)
def build_model():
    model = Sequential([
    Dense(312, activation='relu', input_shape=(X.shape[1],)),
    Dropout(0.2),
    Dense(156, activation='relu'),
    Dropout(0.2),
    Dense(78, activation='relu'),
    Dropout(0.15),
    Dense(1)
])
    model.compile(optimizer=Adam(learning_rate=0.001), 
                loss='mean_squared_error', 
                metrics=['mae'])
    return model

# 🔁 Cross-Validation Training
fold = 1
for train_index, test_index in kf.split(X):
    print(f"\n🔁 Fold {fold}")
    X_train, X_test = X[train_index], X[test_index]
    y_train, y_test = y[train_index], y[test_index]

    model = build_model()
    early_stop = tf.keras.callbacks.EarlyStopping(patience=15, restore_best_weights=True)
    
    history = model.fit(
        X_train, y_train,
        validation_split=0.2,
        epochs=100,
        batch_size=128,
        verbose=0,
        callbacks=[early_stop]
    )
    history_all.append(history.history)

    # Predictions
    y_train_pred = model.predict(X_train, verbose=0).flatten()
    y_test_pred = model.predict(X_test, verbose=0).flatten()

    # Store predictions
    train_true_all.extend(y_train)
    train_pred_all.extend(y_train_pred)
    test_true_all.extend(y_test)
    test_pred_all.extend(y_test_pred)

    # Calculate metrics
    r2 = r2_score(y_test, y_test_pred)
    rmse = np.sqrt(mean_squared_error(y_test, y_test_pred))
    mse = mean_squared_error(y_test, y_test_pred)

    r2_scores.append(r2)
    rmse_scores.append(rmse)
    mse_scores.append(mse)
    
    print(f"✅ Fold {fold} R²: {r2:.3f}, RMSE: {rmse:.3f}, MSE: {mse:.3f}")
    
    # 💾 Save model on fold 5
    if fold == 5:
        model.save("Letestfold5.keras")
        
        # Save metrics and scaler
        model_info = {
            'features': features,
            'target': target,
            'metrics': {
                'r2_scores': r2_scores,
                'rmse_scores': rmse_scores,
                'mse_scores': mse_scores,
                'average_r2': np.mean(r2_scores),
                'average_rmse': np.mean(rmse_scores),
                'average_mse': np.mean(mse_scores)
            },
            'scaler_params': {
                'min': scaler.min_.tolist(),
                'scale': scaler.scale_.tolist()
            }
        }
        
        with open('model_metrics.json', 'w') as f:
            json.dump(model_info, f, indent=4)
    
    fold += 1

# 📊 Final Metrics
print("\n📊 Final 5-Fold CV Results:")
print(f"R²: {np.mean(r2_scores):.3f} ± {np.std(r2_scores):.3f}")
print(f"RMSE: {np.mean(rmse_scores):.3f} ± {np.std(rmse_scores):.3f}")
print(f"MSE: {np.mean(mse_scores):.3f} ± {np.std(mse_scores):.3f}")

# 📈 Enhanced Scatter Plots with R², RMSE, MSE
# 📈 Scatter Plots with R², RMSE, MSE
plt.figure(figsize=(21, 6))

# Training plot
train_r2 = r2_score(train_true_all, train_pred_all)
train_rmse = np.sqrt(mean_squared_error(train_true_all, train_pred_all))
train_mse = mean_squared_error(train_true_all, train_pred_all)

plt.subplot(1, 3, 1)
plt.scatter(train_true_all, train_pred_all, alpha=0.3, s=5, color='#000000')
plt.plot([min(train_true_all), max(train_true_all)], [min(train_true_all), max(train_true_all)], 'r--')
plt.title(f"Training Set\nR²={train_r2:.3f} | RMSE={train_rmse:.2f} | MSE={train_mse:.2f}")
plt.xlabel("Actual SMDI")
plt.ylabel("Predicted SMDI")

# Testing plot
test_r2 = r2_score(test_true_all, test_pred_all)
test_rmse = np.sqrt(mean_squared_error(test_true_all, test_pred_all))
test_mse = mean_squared_error(test_true_all, test_pred_all)

plt.subplot(1, 3, 2)
plt.scatter(test_true_all, test_pred_all, alpha=0.3, s=5, color='#000000')
plt.plot([min(test_true_all), max(test_true_all)], [min(test_true_all), max(test_true_all)], 'r--')
plt.title(f"Testing Set\nR²={test_r2:.3f} | RMSE={test_rmse:.2f} | MSE={test_mse:.2f}")
plt.xlabel("Actual SMDI")
plt.ylabel("Predicted SMDI")

plt.tight_layout()
plt.savefig('actual_vs_predicted_3plots.png', dpi=300)
plt.show()

# 📉 Training History Plot (MSE)
plt.figure(figsize=(12, 5))
for i, history in enumerate(history_all):
    plt.plot(history['loss'], label=f'Fold {i+1} Train')
    plt.plot(history['val_loss'], label=f'Fold {i+1} Val', linestyle='--')
plt.title('Training and Validation MSE Across Folds')
plt.ylabel('MSE')
plt.xlabel('Epoch')
plt.legend()
plt.savefig('training_history_mse.png', dpi=300)
plt.show()


## Relative Importance of Features for DFNN ##

import shap
from tensorflow.keras.models import load_model
import json
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
import tensorflow as tf

# Assumes X_test, y_test, features are already defined

# 🔁 Reload trained model
print("\n🔍 Loading trained DFNN model...")
loaded_model = load_model("Msc_Project_All/dfnn_final1_model_fold5.keras")

# 🔍 Calculate Permutation-Based Relative Importance
print("\n🔍 Calculating Permutation-Based Relative Importance")
baseline_pred = loaded_model.predict(X_test, verbose=0).flatten()
baseline_mse = mean_squared_error(y_test, baseline_pred)

importance_scores = []
for i, feature in enumerate(features):
    X_test_permuted = X_test.copy()
    np.random.shuffle(X_test_permuted[:, i])
    permuted_pred = loaded_model.predict(X_test_permuted, verbose=0).flatten()
    permuted_mse = mean_squared_error(y_test, permuted_pred)
    importance = permuted_mse - baseline_mse
    importance_scores.append(importance)

# Normalize importance scores
total_importance = sum(importance_scores)
relative_importance = [(score / total_importance) * 100 for score in importance_scores]

# Sort by importance descending
sorted_indices = np.argsort(relative_importance)[::-1]
sorted_features = [features[i] for i in sorted_indices]
sorted_importance = [relative_importance[i] for i in sorted_indices]

# 📊 Bar Plot of Permutation Importance (Sorted)
plt.figure(figsize=(10, 6))
sns.barplot(x=sorted_importance, y=sorted_features, palette='viridis')
plt.title('Relative Importance of Features for DFNN', fontsize=14)
plt.xlabel('Relative Importance (%)')
plt.ylabel('Impact Factors')
plt.tight_layout()
plt.savefig('DFNN_feature_importance_sorted.png', dpi=300)
plt.show()

# Save to JSON
model_info['feature_importance'] = {
    'features': sorted_features,
    'relative_importance': sorted_importance
}
with open('model_metrics.json', 'w') as f:
    json.dump(model_info, f, indent=4)
