import os
import re
import numpy as np
import rasterio
from rasterio.transform import from_origin
import glob

# --- Paths ---
input_dir = r"E:\F_Data\1.All Picture&Graph for Project\DFNN\Update result 2\Predicted tif"
output_dir = r"E:\F_Data\1.All Picture&Graph for Project\DFNN\Update result 2\Predicted tif\CombainedYears"

# --- Create output directory if it doesn't exist ---
os.makedirs(output_dir, exist_ok=True)

# --- List all TIFF files ---
tiff_files = sorted(glob.glob(os.path.join(input_dir, "Predicted_SMDI_*.tif")))

# --- Define years ---
years = range(2001, 2021)  # 2001 to 2020 inclusive

# --- Function to combine TIFFs and calculate mean for a given year ---
def combine_yearly_tiff(year):
    # Identify files for the given year and months (April to October)
    pattern = re.compile(rf"Predicted_SMDI_{year}_(0[4-9]|10)\.tif$")
    year_files = [f for f in tiff_files if pattern.search(os.path.basename(f))]
    
    # Check if files exist for the year
    if not year_files:
        print(f"No files found for year {year}")
        return
    
    # Load and check shapes of all monthly TIFFs
    stacks = []
    first_shape = None
    for tif_path in year_files:
        with rasterio.open(tif_path) as src:
            data = src.read(1)
            shape = data.shape
            if first_shape is None:
                first_shape = shape
                print(f"Reference shape for year {year}: {first_shape}")
            elif shape != first_shape:
                print(f"Shape mismatch in {os.path.basename(tif_path)}: {shape} vs {first_shape}")
            stacks.append(data)
    
    # Convert to numpy array with alignment check
    try:
        stack = np.array(stacks)
    except ValueError as e:
        print(f"Error stacking arrays for year {year}: {e}")
        # Attempt to resample to common shape if mismatch
        aligned_stacks = []
        with rasterio.open(year_files[0]) as ref:
            for tif_path in year_files:
                with rasterio.open(tif_path) as src:
                    # Resample to reference shape if needed (simple nearest neighbor)
                    data = src.read(1, out_shape=first_shape, resampling=rasterio.enums.Resampling.nearest)
                    aligned_stacks.append(data)
        stack = np.array(aligned_stacks)
        print(f"Resampled to common shape: {first_shape} for year {year}")
    
    # Calculate mean across months, handling NA values
    mean_grid = np.nanmean(stack, axis=0)
    smdi_mean = np.nanmean(mean_grid)  # Overall mean SMDI for the year
    print(f"Year: {year}, SMDI Mean: {smdi_mean}, Min: {np.nanmin(mean_grid)}, Max: {np.nanmax(mean_grid)}")
    
    # Use the first file's metadata for output
    with rasterio.open(year_files[0]) as first_tif:
        transform = first_tif.transform
        crs = first_tif.crs
        height, width = first_tif.shape
    
    # Define output file name
    output_file = os.path.join(output_dir, f"Combined_SMDI_{year}_Apr-Oct.tif")
    
    # Write yearly mean GeoTIFF
    with rasterio.open(
        output_file,
        'w',
        driver='GTiff',
        height=height,
        width=width,
        count=1,
        dtype='float32',
        crs=crs,
        transform=transform,
        nodata=np.nan,
        compress='lzw'
    ) as dst:
        dst.write(mean_grid.astype('float32'), 1)
    
    print(f"Combined TIFF created for year {year}: {output_file}")

# --- Loop through each year and combine TIFFs ---
for year in years:
    combine_yearly_tiff(year)


