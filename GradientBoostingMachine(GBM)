# 3. GradientBoostingMachine(GBM) with cross validation fold 5 

# Import required libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.ensemble import GradientBoostingRegressor
from sklearn.metrics import r2_score, mean_squared_error
from sklearn.model_selection import cross_val_score

# Load the data
data_path = "E:/F_Data/Experiment_1/7.Growing season month/1. CSV_File/Combined_Growing.csv"
df = pd.read_csv(data_path)

# Drop rows with missing values
df = df.dropna()

# Randomly sample 130,000 rows (100k train, 30k test)
df_sampled = df.sample(n=130000, random_state=42)

# Split into train and test sets
train_df = df_sampled.sample(n=100000, random_state=1)
test_df = df_sampled.drop(train_df.index)

# Define predictors and target
features = ['EDI', 'PAI', 'PCI', 'SPEI3', 'SPEI6', 'SPEI12',
            'SPI3', 'SPI6', 'SPI12', 'TCI', 'VCI', 'VHI']
target = 'SMDI'

X_train = train_df[features]
y_train = train_df[target]
X_test = test_df[features]
y_test = test_df[target]

# Initialize and train Gradient Boosting Regressor (GBM)
model_gbm = GradientBoostingRegressor(
    n_estimators=200,
    learning_rate=0.2,
    max_depth=6,
    subsample=0.8,
    random_state=42
)
model_gbm.fit(X_train, y_train)

# Predict on the train and test data
train_pred = model_gbm.predict(X_train)
test_pred = model_gbm.predict(X_test)

# Evaluate the model performance
train_r2 = r2_score(y_train, train_pred)
test_r2 = r2_score(y_test, test_pred)
train_rmse = np.sqrt(mean_squared_error(y_train, train_pred))
test_rmse = np.sqrt(mean_squared_error(y_test, test_pred))
train_mse = mean_squared_error(y_train, train_pred)
test_mse = mean_squared_error(y_test, test_pred)

# Perform 5-fold cross-validation
cv_scores = cross_val_score(model_gbm, X_train, y_train, cv=5, scoring='neg_mean_squared_error')
cv_mse_scores = -cv_scores  # Convert negative MSE to positive
cv_mse_mean = cv_mse_scores.mean()
cv_mse_std = cv_mse_scores.std()

# Print results
print(f"Training R²: {train_r2:.3f} | RMSE: {train_rmse:.3f} | MSE: {train_mse:.3f}")
print(f"Testing  R²: {test_r2:.3f} | RMSE: {test_rmse:.3f} | MSE: {test_mse:.3f}")
print(f"Cross-Validation MSE: {cv_mse_mean:.3f} (± {cv_mse_std:.3f})")

# Plot Actual vs Predicted and MSE
plt.figure(figsize=(21, 6))

# Training plot
plt.subplot(1, 3, 1)
plt.scatter(y_train, train_pred, alpha=0.3, s=5, color='tab:blue')
plt.title(f"Training Set\nR² = {train_r2:.3f} | RMSE = {train_rmse:.2f} | MSE = {train_mse:.2f}")
plt.xlabel("Actual SMDI")
plt.ylabel("Predicted SMDI")
plt.plot([y_train.min(), y_train.max()], [y_train.min(), y_train.max()], 'r--')

# Testing plot
plt.subplot(1, 3, 2)
plt.scatter(y_test, test_pred, alpha=0.3, s=5, color='tab:blue')
plt.title(f"Testing Set\nR² = {test_r2:.3f} | RMSE = {test_rmse:.2f} | MSE = {test_mse:.2f}")
plt.xlabel("Actual SMDI")
plt.ylabel("Predicted SMDI")
plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--')

plt.tight_layout()
plt.savefig('training_history_mse.png', dpi=300)
plt.show()
